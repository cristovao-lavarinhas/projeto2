<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.projetojavafx.Controller.GerirDocumentosController" stylesheets="@style.css">

    <VBox spacing="20" alignment="TOP_CENTER" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" style="-fx-padding: 20; -fx-background-color: #f5f6fa;">

        <Label text="Gestão de Documentos" styleClass="page-title"/>

        <TableView fx:id="documentosTable" prefHeight="500" styleClass="modern-table" editable="false">
            <columns>

                <TableColumn fx:id="nomeColumn" text="Nome Motorista"/>
                <TableColumn fx:id="tipoDocColumn" text="Tipo Documento"/>
                <TableColumn fx:id="expiracaoColumn" text="Data de Expiração"/>
                <TableColumn fx:id="estadoColumn" text="Estado"/>
                <TableColumn fx:id="acoesColumn" text="Ações" />

            </columns>
        </TableView>

    </VBox>
</AnchorPane>
